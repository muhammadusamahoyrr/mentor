# --- HTTP ---
PORT=3008

# --- Service-to-service trust ---
# Must be IDENTICAL to the value agent-service sends. This endpoint runs every
# clinical skill, so only our own services may reach it.
#   node -e "console.log(require('crypto').randomBytes(48).toString('base64url'))"
INTERNAL_SERVICE_TOKEN=

# --- Auth (must be IDENTICAL across every service, or auth-service's tokens
# will not verify here). The caller's doctor JWT arrives on the Authorization
# header and is forwarded verbatim to the sibling services below.
JWT_SECRET=

# --- Skills that call sibling services (the caller's JWT is forwarded) ---
FILE_SERVICE_URL=http://localhost:3005
APPOINTMENT_SERVICE_URL=http://localhost:3002

# --- web_search skill (Brave Search API) — https://brave.com/search/api/ ---
BRAVE_API_KEY=

# --- retrieve_docs skill (vector recall) ---
CHROMA_URL=http://localhost:8000
VOYAGE_API_KEY=
VOYAGE_MODEL=voyage-3

# --- Trace store (shared with agent-service; Redis is what lets the two halves
# of a run's trace stitch together across the MCP boundary) ---
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
TRACE_TTL=3600

# --- stdio demo only (Claude Code / Cursor): the one doctor this process acts as
MCP_DOCTOR_JWT=
