PORT=
MONGODB_URI=
FRONTEND_URL=
JWT_SECRET=
AUTH_SERVICE_URL=
NOTIFICATION_SERVICE_URL=

# Shared secret for service-to-service calls (POST /api/notifications/events).
# Must be IDENTICAL across every service. notification-service refuses to start
# without it, rather than leave the event endpoint open.
# Generate with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
INTERNAL_SERVICE_TOKEN=
