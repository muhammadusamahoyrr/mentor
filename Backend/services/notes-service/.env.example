# SQLite database file (created by `prisma migrate dev`). Path is relative to prisma/schema.prisma.
DATABASE_URL=
PORT=
FRONTEND_URL=

# Must be identical across every service, or tokens minted by auth-service will
# not verify here. Generate with:
#   node -e "console.log(require('crypto').randomBytes(48).toString('base64url'))"
# Never commit the real value, and never use a dictionary word.
JWT_SECRET=

# notes-service holds no appointment data, so it asks appointment-service whether
# the caller is really on the appointment before serving that appointment's notes.
APPOINTMENT_SERVICE_URL=
