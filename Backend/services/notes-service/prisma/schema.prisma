// Prisma schema — the ORM layer.
// Run `npx prisma migrate dev` to turn these models into real SQL migration files.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// Parent side of the one-to-many relationship.
model Doctor {
  id Int @id @default(autoincrement())

  // The auth-service user _id (a Mongo ObjectId). Local rows are upserted from
  // the JWT / appointment payload, so notes can hang off a real platform user
  // while the relation below still uses a local integer key.
  externalId String? @unique

  name           String
  email          String? @unique
  specialization String?
  createdAt      DateTime @default(now())

  // A doctor has many notes.
  notes Note[]
}

// Child side — each Note belongs to exactly one Doctor (foreign key).
model Note {
  id      Int    @id @default(autoincrement())
  title   String
  content String

  // Set when the note was written against a consultation. Holds the
  // appointment-service Mongo _id; null for standalone notes.
  appointmentId String?

  // Whoever actually typed the note — may be the patient, not the doctor the
  // note is filed under.
  authorId   String?
  authorName String?
  authorRole String?

  // True when the note was drafted by the AI agent and has NOT yet been
  // confirmed by a doctor. An unreviewed clinical note must never be presented
  // as final: studies put the error rate of AI-drafted notes high enough that a
  // human confirmation step is a safety requirement, not a nicety. Flipped to
  // false only via POST /api/notes/:id/confirm by a doctor.
  unreviewed Boolean @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // The relationship: doctorId is the foreign key referencing Doctor.id.
  doctor   Doctor @relation(fields: [doctorId], references: [id], onDelete: Cascade)
  doctorId Int

  @@index([appointmentId])
}

// A vital-sign reading recorded by a patient about themselves.
//
// The patient dashboard used to chart a hardcoded array of heart-rate and blood
// pressure numbers that no service had ever stored. This is where those readings
// actually live now.
model Vital {
  id Int @id @default(autoincrement())

  // The auth-service user id of the patient the reading belongs to. Taken from
  // the JWT on write, never from the request body.
  patientId String

  // When the reading was taken — which is not necessarily when it was entered.
  recordedAt DateTime @default(now())

  // Every metric is optional: a reading might be weight alone, or blood pressure
  // alone. Validation enforces that at least one is present.
  heartRate Int?
  systolic  Int?
  diastolic Int?
  weightKg  Float?

  createdAt DateTime @default(now())

  @@index([patientId, recordedAt])
}
