{
  "info": {
    "_postman_id": "notes-svc-2026-week2-0001",
    "name": "Notes Service (Week 2)",
    "description": "CRUD REST API for the Notes resource (Prisma + SQLite). Doctor -> Notes one-to-many relationship. Start the server with `npm start` before sending requests.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:3005",
      "type": "string"
    }
  ],
  "item": [
    {
      "name": "0. Health check",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/health",
          "host": ["{{baseUrl}}"],
          "path": ["health"]
        }
      }
    },
    {
      "name": "Doctors",
      "item": [
        {
          "name": "1. Create doctor",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Dr. House\",\n  \"email\": \"house@demo.com\",\n  \"specialization\": \"Diagnostics\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": {
              "raw": "{{baseUrl}}/api/doctors",
              "host": ["{{baseUrl}}"],
              "path": ["api", "doctors"]
            }
          }
        },
        {
          "name": "2. List doctors (with their notes)",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/doctors",
              "host": ["{{baseUrl}}"],
              "path": ["api", "doctors"]
            }
          }
        }
      ]
    },
    {
      "name": "Notes (CRUD)",
      "item": [
        {
          "name": "3. Create note",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"doctorId\": 1,\n  \"title\": \"BP reading\",\n  \"content\": \"120/80, patient stable\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": {
              "raw": "{{baseUrl}}/api/notes",
              "host": ["{{baseUrl}}"],
              "path": ["api", "notes"]
            }
          }
        },
        {
          "name": "4. List all notes",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/notes",
              "host": ["{{baseUrl}}"],
              "path": ["api", "notes"]
            }
          }
        },
        {
          "name": "5. List notes filtered by doctor",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/notes?doctorId=1",
              "host": ["{{baseUrl}}"],
              "path": ["api", "notes"],
              "query": [{ "key": "doctorId", "value": "1" }]
            }
          }
        },
        {
          "name": "6. Get one note (doctor joined in)",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/notes/1",
              "host": ["{{baseUrl}}"],
              "path": ["api", "notes", "1"]
            }
          }
        },
        {
          "name": "7. Update note",
          "request": {
            "method": "PUT",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"title\": \"Morning BP reading\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": {
              "raw": "{{baseUrl}}/api/notes/1",
              "host": ["{{baseUrl}}"],
              "path": ["api", "notes", "1"]
            }
          }
        },
        {
          "name": "8. Delete note",
          "request": {
            "method": "DELETE",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/notes/1",
              "host": ["{{baseUrl}}"],
              "path": ["api", "notes", "1"]
            }
          }
        },
        {
          "name": "9. (Test) Invalid note -> 400",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"doctorId\": 1,\n  \"title\": \"\",\n  \"content\": \"x\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": {
              "raw": "{{baseUrl}}/api/notes",
              "host": ["{{baseUrl}}"],
              "path": ["api", "notes"]
            }
          }
        },
        {
          "name": "10. (Test) Note for missing doctor -> 404",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"doctorId\": 999999,\n  \"title\": \"x\",\n  \"content\": \"y\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": {
              "raw": "{{baseUrl}}/api/notes",
              "host": ["{{baseUrl}}"],
              "path": ["api", "notes"]
            }
          }
        }
      ]
    }
  ]
}
