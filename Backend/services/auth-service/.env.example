PORT=
# Use the STANDARD (non-SRV) connection string:
#   mongodb://<user>:<pass>@<h1>:27017,<h2>:27017,<h3>:27017/<db>?ssl=true&replicaSet=<setName>&authSource=admin&retryWrites=true&w=majority
#
# mongodb+srv:// is tidier but needs BOTH an SRV and a TXT DNS lookup. TXT lookups
# for Atlas time out on some networks (certain routers, captive portals, corporate
# DNS). When that happens every Mongo-backed service dies at boot with
# "queryTxt ETIMEOUT" — which looks nothing like a DNS problem and is maddening to
# diagnose. The standard form needs only ordinary A-record lookups, which work.
#
# To build it, connect once from a working network and ask the server itself for
# the two things the SRV and TXT records would have supplied:
#   db.hello().hosts      -> the host list
#   db.hello().setName    -> the replicaSet name
#
# Trade-off: the hostnames are pinned here, so regenerate this if the Atlas cluster
# is ever migrated or rescaled.
MONGO_URI=
FRONTEND_URL=
KAFKA_BROKER=
KAFKA_SSL=
KAFKA_SASL_MECHANISM=
KAFKA_USERNAME=
KAFKA_PASSWORD=
JWT_SECRET=
NOTIFICATION_SERVICE_URL=
# Shared secret for service-to-service calls (POST /api/notifications/events).
# Must be IDENTICAL across every service. notification-service refuses to start
# without it, rather than leave the event endpoint open.
# Generate with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
INTERNAL_SERVICE_TOKEN=
