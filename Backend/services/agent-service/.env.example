# --- HTTP ---
PORT=3007
FRONTEND_URL=http://localhost:3000

# --- Auth (must be IDENTICAL across every service, or auth-service's tokens
# will not verify here). Generate with:
#   node -e "console.log(require('crypto').randomBytes(48).toString('base64url'))"
JWT_SECRET=

# --- LLM provider (the planner/executor) ---
# The ReAct loop runs on Claude or Gemini. Pick explicitly, or leave blank and it
# auto-detects from whichever API key is set below (Anthropic wins if both).
AGENT_PROVIDER=            # anthropic | gemini  (blank = auto)

# Claude — https://console.anthropic.com/ -> API keys
ANTHROPIC_API_KEY=
# claude-sonnet-5 for the loop; claude-opus-4-8 for max multi-hop reasoning.
AGENT_MODEL=claude-sonnet-5

# Gemini — https://aistudio.google.com/apikey  (free tier available)
# GOOGLE_API_KEY is accepted as an alias for GEMINI_API_KEY.
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

# Guardrail: max planner->executor loops before the agent gives up (default 6).
AGENT_MAX_STEPS=6

# --- web_search skill (Brave Search API) ---
# https://brave.com/search/api/
BRAVE_API_KEY=

# --- Skills that call sibling services (JWT is forwarded from the caller) ---
FILE_SERVICE_URL=http://localhost:3005
APPOINTMENT_SERVICE_URL=http://localhost:3002

# Local read_file skill: folder it reads .txt/.pdf docs from (default ./docs).
AGENT_DOCS_DIR=

# --- Session memory (Redis; falls back to an in-process store if absent) ---
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
# Session TTL in seconds (default 1800 = 30 min).
AGENT_SESSION_TTL=1800

# --- Tool-call hook (Kafka; audit-service persists agent.tool.called) ---
KAFKA_BROKERS=localhost:9092
# Set to 1 to disable the Kafka audit sink (deployments without a broker, tests).
AGENT_DISABLE_KAFKA=

# --- Vector recall (Phase 4, optional / cuttable) ---
CHROMA_URL=http://localhost:8000
# Embeddings provider for ChromaDB ingestion + retrieval.
VOYAGE_API_KEY=
VOYAGE_MODEL=voyage-3
# JWT used by scripts/ingest.js to pull documents for embedding (or pass --token).
AGENT_INGEST_TOKEN=
