# --- HTTP ---
PORT=3007
FRONTEND_URL=http://localhost:3000

# --- Auth (must be IDENTICAL across every service, or auth-service's tokens
# will not verify here). Generate with:
#   node -e "console.log(require('crypto').randomBytes(48).toString('base64url'))"
JWT_SECRET=

# --- LLM provider (the planner/executor) ---
# The ReAct loop runs on Claude, Gemini or OpenRouter. Pick explicitly, or leave
# blank and it auto-detects from whichever API key is set below.
AGENT_PROVIDER=            # anthropic | gemini | openrouter  (blank = auto)

# FALLBACK CHAIN. When a provider fails, the request rolls over to the next one
# instead of failing the doctor's question — which is what keeps a rate-limited
# free tier usable. Rolls over on 429 / 5xx / network / bad key; NOT on a 4xx we
# caused (every provider would reject that identically).
#
# Leave blank and the chain is built for you: the primary first, then every other
# provider you have a key for. So just adding OPENROUTER_API_KEY below is enough.
# Set it to force an exact order, e.g. gemini,openrouter,anthropic
AGENT_PROVIDERS=

# NOTE: mid-stream, fallback only happens if NOTHING has been sent to the screen
# yet — switching after tokens are visible would print a second answer over the
# first.

# Claude — https://console.anthropic.com/ -> API keys
ANTHROPIC_API_KEY=
# claude-sonnet-5 for the loop; claude-opus-4-8 for max multi-hop reasoning.
AGENT_MODEL=claude-sonnet-5

# Gemini — https://aistudio.google.com/apikey  (free tier available)
# GOOGLE_API_KEY is accepted as an alias for GEMINI_API_KEY.
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

# OpenRouter — https://openrouter.ai/keys  (one key, many models, free tier)
# The best fallback partner: when Gemini's free tier rate-limits you mid-question,
# this can still answer. The key alone is enough — nothing else to configure.
#
# `openrouter/free` auto-routes across whatever free models are currently
# available AND supports tool calling, which the ReAct loop needs. Prefer it to a
# pinned slug: a specific ":free" model can stop being free and start 404-ing.
OPENROUTER_API_KEY=
OPENROUTER_MODEL=openrouter/free
# Optional, shown on your OpenRouter dashboard:
OPENROUTER_SITE_URL=http://localhost:3000
OPENROUTER_APP_NAME=CareLoop clinical research agent

# Guardrail: max planner->executor loops before the agent gives up.
# 6 proved too low in the first live run — a research question spent all six on
# progressively refined searches and returned "reached the maximum steps".
AGENT_MAX_STEPS=10

# --- Multi-agent orchestration (supervisor + workers) ---
# single     = one agent with every tool (default, cheapest)
# supervisor = a supervisor routes the question to specialist workers
#              (records / research / scheduling), each a small agent with a
#              narrow tool slice, then composes one answer from their findings.
# Opt-in on purpose: it costs several times more model calls per question and
# does not automatically produce a better answer — it fragments context.
AGENT_MODE=single

# parallel   = independent workers run concurrently (default; the latency win)
# sequential = one worker at a time. Slower, but a burst of concurrent calls is
#              exactly what trips a free tier's per-minute limit — use this if
#              you are seeing 429s during orchestration.
AGENT_ORCHESTRATION=parallel

# Budget guards, so a runaway fan-out cannot burn the whole quota.
AGENT_MAX_WORKERS=3          # max workers per question (fan-out cap)
AGENT_WORKER_MAX_STEPS=3     # tool loops allowed inside ONE worker
AGENT_WORKER_TIMEOUT_MS=45000 # a stuck worker is dropped, not waited on

# Per-role models: the supervisor does the reasoning that matters, workers do
# bounded retrieval and can run cheaper. Blank = the provider's default model.
AGENT_SUPERVISOR_MODEL=
AGENT_WORKER_MODEL=

# The answer's structured trailer (sources + confidence) is validated with Zod.
# When it comes back malformed the model is asked once more for just that line.
# Set to 0 to skip that retry — one fewer call per bad answer, which matters on
# a rate-limited free tier; confidence then falls back to the plain marker.
AGENT_TRAILER_REPAIR=1

# --- web_search skill (Brave Search API) ---
# https://brave.com/search/api/
BRAVE_API_KEY=

# --- Tools over MCP (healthcare-mcp) ---
# Set this and the agent runs every platform skill inside the MCP server, with
# the caller's JWT forwarded on the transport. Leave it BLANK to fall back to
# running the skills in-process (offline demo, CLI harness, tests).
HEALTHCARE_MCP_URL=http://localhost:3008/mcp
# Service-to-service trust for that call. Must match healthcare-mcp's value.
#   node -e "console.log(require('crypto').randomBytes(48).toString('base64url'))"
INTERNAL_SERVICE_TOKEN=

# --- Skills that call sibling services (JWT is forwarded from the caller) ---
# Used by the in-process fallback; healthcare-mcp has its own copies of these.
FILE_SERVICE_URL=http://localhost:3005
APPOINTMENT_SERVICE_URL=http://localhost:3002

# Local read_file skill: folder it reads .txt/.pdf docs from (default ./docs).
AGENT_DOCS_DIR=

# --- Session memory (Redis; falls back to an in-process store if absent) ---
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
# Session TTL in seconds (default 1800 = 30 min).
AGENT_SESSION_TTL=1800

# --- Tool-call hook (Kafka; audit-service persists agent.tool.called) ---
KAFKA_BROKERS=localhost:9092
# Set to 1 to disable the Kafka audit sink (deployments without a broker, tests).
AGENT_DISABLE_KAFKA=

# --- Vector recall (Phase 4, optional / cuttable) ---
CHROMA_URL=http://localhost:8000
# Embeddings provider for ChromaDB ingestion + retrieval.
VOYAGE_API_KEY=
VOYAGE_MODEL=voyage-3
# JWT used by scripts/ingest.js to pull documents for embedding (or pass --token).
AGENT_INGEST_TOKEN=
